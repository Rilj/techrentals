<style>
    .loans-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .loan-card {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 24px;
        border-bottom: 1px solid var(--border);
    }

    .loan-card:last-child {
        border-bottom: none;
    }

    .loan-image {
        width: 80px;
        height: 80px;
        border-radius: 12px;
        object-fit: cover;
        background: #222;
    }

    .loan-details {
        flex: 1;
    }

    .loan-details h4 {
        font-size: 1.1rem;
        margin-bottom: 8px;
    }

    .loan-meta {
        display: flex;
        gap: 20px;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .loan-meta span {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .loan-actions {
        text-align: right;
    }

    .loan-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 12px;
    }

    @media (max-width: 768px) {
        .loan-card {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .loan-actions {
            width: 100%;
            text-align: left;
            margin-top: 16px;
        }
    }
</style>

<div class="dashboard-header animate-in">
    <h1>Peminjaman Saya</h1>
    <p>Kelola barang yang sedang Anda pinjam</p>
</div>

<div class="card animate-in" style="padding: 0; overflow: hidden;">
    <% if(loans && loans.length > 0) { %>
        <% loans.forEach(loan => { %>
        <div class="loan-card">
            <div class="loan-image">
                <% if(loan.Item.image) { %>
                    <img src="/uploads/<%= loan.Item.image %>" style="width: 100%; height: 100%; border-radius: 12px; object-fit: cover;">
                <% } else { %>
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 2rem;">📦</div>
                <% } %>
            </div>
            <div class="loan-details">
                <h4><%= loan.Item.nama_barang %></h4>
                <div class="loan-meta">
                    <span></span>
                    <span>🏷️ <%= loan.Item.kode_unit %></span>
                    <span>
                        <% if(loan.status === 'borrowed') { %>
                            <span class="badge badge-warning">Sedang Dipinjam</span>
                        <% } else if(loan.status === 'return_requested') { %>
                            <span class="badge badge-info">Pengembalian Diajukan</span>
                        <% } else if(loan.status === 'pending') { %>
                            <span class="badge badge-secondary">Menunggu Persetujuan</span>
                        <% } else if(loan.status === 'returned') { %>
                            <span class="badge badge-success">Sudah Dikembalikan</span>
                        <% } else if(loan.status === 'rejected') { %>
                            <span class="badge badge-danger">Ditolak</span>
                        <% } else { %>
                            <span class="badge"><%= loan.status %></span>
                        <% } %>
                    </span>
                </div>
            </div>
            <div class="loan-actions">
                <div class="loan-price">
                    Rp <%= loan.totalPrice %>
                </div>

                <% if(loan.status === 'borrowed') { %>
                    <form action="/loan/return/<%= loan.id %>" method="POST">
                        <button class="btn btn-secondary">Ajukan Pengembalian</button>
                    </form>
                <% } else { %>
                    <span style="color: var(--text-secondary); font-size: 0.9rem;"></span>
                <% } %>
            </div>
        </div>
        <% }) %>
    <% } else { %>
    <div class="empty-state" style="padding: 80px 40px;">
        <div class="empty-state-icon">📭</div>
        <h3>Tidak Ada Peminjaman Aktif</h3>
        <p>Anda belum meminjam barang apapun saat ini.</p>
        <a href="/items" class="btn btn-primary" style="margin-top: 24px;">Jelajahi Barang</a>
    </div>
    <% } %>
</div>