<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        position: relative;
    }

    .login-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 48px;
        width: 100%;
        max-width: 420px;
        position: relative;
        overflow: hidden;
    }

    .login-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: var(--gradient-red);
    }

    .login-logo {
        text-align: center;
        margin-bottom: 32px;
    }

    .login-logo img {
        width: 120px;
        height: 120px;
        border-radius: 20px;
        object-fit: cover;
        border: 3px solid var(--border);
        box-shadow: 0 10px 40px rgba(255, 0, 0, 0.2);
    }

    .login-logo h2 {
        margin-top: 20px;
        font-size: 1.8rem;
        font-weight: 700;
    }

    .login-logo p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-top: 8px;
    }

    .input-group {
        position: relative;
        margin-bottom: 20px;
    }

    .input-group i {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-secondary);
        font-style: normal;
    }

    .input-group .form-control {
        padding-left: 48px;
    }

    .login-btn {
        width: 100%;
        padding: 14px;
        background: var(--gradient-red);
        border: none;
        border-radius: 12px;
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
        box-shadow: 0 4px 15px rgba(255, 0, 0, 0.3);
    }

    .login-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 0, 0, 0.4);
    }

    .login-footer {
        text-align: center;
        margin-top: 24px;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    @media (max-width: 480px) {
        .login-card {
            padding: 32px 24px;
        }
    }
</style>

<div class="login-page">
    <div class="login-card animate-in">
        <div class="login-logo">
            <img src="/assets/alastor-service.jpg" alt="SarpraTech">
            <h2>Welcome Back</h2>
            <p>Sistem Peminjaman SarpraTech</p>
        </div>
        
        <form method="POST" action="/login">
            <div class="input-group">
                <i>✉</i>
                <input type="email" name="email" class="form-control" placeholder="Email address" required>
            </div>
            <div class="input-group">
                <i>🔒</i>
                <input type="password" name="password" class="form-control" placeholder="Password" required>
            </div>
            <button type="submit" class="login-btn">Sign In</button>
        </form>
        
        <div class="login-footer">
            <p>© 2026 SarpraTech. All rights reserved.</p>
        </div>
    </div>
</div>