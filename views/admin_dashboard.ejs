<style>
    .admin-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 0, 0, 0.1);
        border: 1px solid rgba(255, 0, 0, 0.3);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        color: var(--primary);
        font-weight: 600;
        margin-bottom: 24px;
    }

    .admin-grid {
        display: grid;
        grid-template-columns: 380px 1fr;
        gap: 24px;
        align-items: start;
    }

    .user-form-card {
        position: sticky;
        top: 90px;
    }

    .user-form-card h3 {
        font-size: 1.2rem;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .requests-card {
        padding: 0;
        overflow: hidden;
    }

    .card-header {
        padding: 20px 24px;
        background: rgba(255, 0, 0, 0.05);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .card-header h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }

    .action-btns {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .btn-approve-icon {
        background: rgba(0, 208, 132, 0.15);
        color: var(--success);
    }

    .btn-approve-icon:hover {
        background: var(--success);
        color: #000;
    }

    .btn-reject-icon {
        background: rgba(255, 71, 87, 0.15);
        color: var(--danger);
    }

    .btn-reject-icon:hover {
        background: var(--danger);
        color: white;
    }

    .user-info-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--gradient-red);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: white;
        font-size: 1rem;
    }

    .user-details h5 {
        margin: 0;
        font-size: 0.95rem;
        color: var(--text-primary);
    }

    .user-details small {
        color: var(--text-secondary);
        font-size: 0.8rem;
    }

    .fine-select {
        padding: 8px 12px;
        background: #0f0f0f;
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 0.85rem;
        cursor: pointer;
    }

    .returns-section {
        margin-top: 40px;
    }

    @media (max-width: 1024px) {
        .admin-grid {
            grid-template-columns: 1fr;
        }
        
        .user-form-card {
            position: static;
        }
    }
</style>

<div class="dashboard-header animate-in">
    <div class="admin-badge">
        <span>🛡️</span> ADMIN CONTROL PANEL
    </div>
    <h1>Kelola Peminjaman</h1>
    <p>Verifikasi permintaan pengguna dan proses pengembalian barang</p>
</div>

<div class="stats-grid animate-in">
    <div class="stat-card">
        <h4>Permintaan Pending</h4>
        <div class="value"><%= pendingLoans.length %></div>
    </div>
    <div class="stat-card">
        <h4>Pengembalian Menunggu</h4>
        <div class="value"><%= returnRequests.length %></div>
    </div>
    <div class="stat-card">
        <h4>Total Diproses Hari Ini</h4>
        <div class="value">-</div>
    </div>
</div>

<div class="admin-grid animate-in">
    <!-- Add User Form -->
    <div class="card user-form-card">
        <h3><span>👤</span> Tambah Pengguna Baru</h3>
        <form action="/admin/add-user" method="POST">
            <div class="form-group">
                <label>Nama Lengkap</label>
                <input type="text" name="name" class="form-control" placeholder="Contoh: John Doe" required>
            </div>
            <div class="form-group">
                <label>Alamat Email</label>
                <input type="email" name="email" class="form-control" placeholder="email@domain.com" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" class="form-control" placeholder="Minimal 8 karakter" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">
                <span>+</span> Daftarkan User
            </button>
        </form>
    </div>

    <!-- Pending Loans -->
    <div class="card requests-card">
        <div class="card-header">
            <h3>Persetujuan Peminjaman</h3>
            <span class="badge badge-warning"><%= pendingLoans.length %> Pending</span>
        </div>
        
        <% if(pendingLoans.length === 0) { %>
        <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h4>Tidak Ada Permintaan</h4>
            <p>Semua permintaan peminjaman telah diproses.</p>
        </div>
        <% } else { %>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Pengguna</th>
                    <th>Barang</th>
                    <th style="text-align: center;">Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% pendingLoans.forEach(loan => { %>
                <tr>
                    <td>
                        <div class="user-info-cell">
                            <div class="user-avatar"><%= loan.User.name.charAt(0).toUpperCase() %></div>
                            <div class="user-details">
                                <h5><%= loan.User.name %></h5>
                                <small><%= loan.User.email %></small>
                            </div>
                        </div>
                    </td>
                    <td>
                        <strong><%= loan.Item.nama_barang %></strong>
                        <div style="font-size: 0.8rem; color: #666;"><%= loan.Item.kode_unit %></div>
                    </td>
                    <td>
                        <div class="action-btns" style="justify-content: center;">
                            <form action="/admin/approve/<%= loan.id %>" method="POST">
                                <button class="btn-icon btn-approve-icon" title="Terima">✓</button>
                            </form>
                            <form action="/admin/reject/<%= loan.id %>" method="POST">
                                <button class="btn-icon btn-reject-icon" title="Tolak">✕</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>

<!-- Returns Section -->
<div class="returns-section animate-in">
    <div class="section-header">
        <h3>Proses Pengembalian Barang</h3>
        <span class="badge badge-info"><%= returnRequests.length %> Menunggu</span>
    </div>
    
    <div class="card" style="padding: 0; overflow: hidden;">
        <% if(returnRequests.length === 0) { %>
        <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <h4>Tidak Ada Pengembalian</h4>
            <p>Tidak ada permintaan pengembalian yang menunggu diproses.</p>
        </div>
        <% } else { %>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Pengguna</th>
                    <th>Barang</th>
                    <th>Tagihan Dasar</th>
                    <th>Kondisi & Denda</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% returnRequests.forEach(loan => { %>
                <tr>
                    <td>
                        <div class="user-info-cell">
                            <div class="user-avatar"><%= loan.User.name.charAt(0).toUpperCase() %></div>
                            <div class="user-details">
                                <h5><%= loan.User.name %></h5>
                            </div>
                        </div>
                    </td>
                    <td>
                        <strong><%= loan.Item.nama_barang %></strong>
                        <div style="font-size: 0.8rem; color: #666;"><%= loan.Item.kode_unit %></div>
                    </td>
                    <td style="font-weight: 600;">Rp <%= loan.totalPrice.toLocaleString() %></td>
                    <td>
                        <form action="/admin/complete-return/<%= loan.id %>" method="POST" id="returnForm<%= loan.id %>">
                            <select name="fine" class="fine-select">
                                <option value="0">✓ Kondisi Baik (Rp 0)</option>
                                <option value="300000">⚠ Rusak/Cacat (Rp 300.000)</option>
                                <option value="500000">✕ Hilang (Rp 500.000)</option>
                            </select>
                    </td>
                    <td>
                            <button class="btn btn-success btn-sm">Selesaikan</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div> 