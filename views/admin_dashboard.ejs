<style>
    .dashboard-header {
        margin-bottom: 30px;
        border-left: 5px solid var(--primary);
        padding-left: 15px;
    }

    /* Stats Grid */
    .stats-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    .stat-card {
        background: var(--card-bg);
        border: 1px solid #333;
        padding: 20px;
        border-radius: 15px;
        text-align: center;
        transition: 0.3s;
    }
    .stat-card:hover { border-color: var(--primary); }
    .stat-card h4 { margin: 0; color: #aaa; font-size: 0.9rem; }
    .stat-card .value { font-size: 2rem; font-weight: 900; color: var(--primary); margin: 10px 0; }

    /* Form Section */
    .action-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 30px;
        align-items: start;
    }

    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; margin-bottom: 5px; font-size: 0.8rem; color: #ccc; }
    .form-group input { width: 100%; box-sizing: border-box; }

    /* Status Badge */
    .status-text {
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 4px 8px;
        border-radius: 4px;
        background: #222;
    }
</style>

<div class="dashboard-header">
    <h1>Admin Control Panel</h1>
    <p>Kelola permintaan pengguna dan inventaris harian.</p>
</div>

<div class="stats-container">
    <div class="stat-card">
        <h4>PENDING REQUESTS</h4>
        <div class="value"><%= pendingLoans.length %></div>
    </div>
    <div class="stat-card">
        <h4>RETURN REQUESTS</h4>
        <div class="value"><%= returnRequests.length %></div>
    </div>
</div>

<div class="action-grid">
    <div class="card">
        <h3 style="color: var(--primary); margin-top: 0;">+ Tambah User</h3>
        <form action="/admin/add-user" method="POST">
            <div class="form-group">
                <label>NAMA LENGKAP</label>
                <input type="text" name="name" placeholder="Contoh: John Doe" required>
            </div>
            <div class="form-group">
                <label>EMAIL</label>
                <input type="email" name="email" placeholder="email@domain.com" required>
            </div>
            <div class="form-group">
                <label>PASSWORD</label>
                <input type="password" name="password" placeholder="******" required>
            </div>
            <button type="submit" class="logout-btn" style="width: 100%; border: none; margin-top: 10px;">Daftarkan User</button>
        </form>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <div style="padding: 20px; background: #1a1a1a; border-bottom: 1px solid #333;">
            <h3 style="margin: 0;">Persetujuan Peminjaman</h3>
        </div>
        <table style="margin-top: 0;">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Nama Barang</th>
                    <th style="text-align: center;">Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% if(pendingLoans.length === 0) { %>
                    <tr><td colspan="3" style="text-align: center; color: #666;">Tidak ada permintaan baru</td></tr>
                <% } %>
                <% pendingLoans.forEach(loan => { %>
                <tr>
                    <td><strong><%= loan.User.name %></strong><br><small><%= loan.User.email %></small></td>
                    <td><%= loan.Item.nama_barang %></td>
                    <td style="text-align: center;">
                        <form action="/admin/approve/<%= loan.id %>" method="POST" style="display:inline;">
                            <button class="btn-approve" title="Terima">✓ Approve</button>
                        </form>
                        <form action="/admin/reject/<%= loan.id %>" method="POST" style="display:inline;">
                            <button class="btn-reject" title="Tolak">✕</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<h3 style="margin-top: 40px;">Proses Pengembalian Barang</h3>
<div class="card" style="padding: 0;">
    <table>
        <thead>
            <tr>
                <th>User</th>
                <th>Barang</th>
                <th>Tagihan Dasar</th>
                <th>Denda & Aksi</th>
            </tr>
        </thead>
        <tbody>
            <% returnRequests.forEach(loan => { %>
            <tr>
                <td><%= loan.User.name %></td>
                <td><%= loan.Item.nama_barang %></td>
                <td>Rp <%= loan.totalPrice.toLocaleString() %></td>
                <td>
                    <form action="/admin/complete-return/<%= loan.id %>" method="POST" style="display: flex; gap: 10px;">
                        <select name="fine" style="flex: 1;">
                            <option value="0">Kondisi Baik (Rp 0)</option>
                            <option value="300000">Rusak/Cacat (Rp 300.000)</option>
                        </select>
                        <button class="btn-approve">Selesaikan</button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>