<style>
    .admin-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, rgba(255,0,0,0.15) 0%, rgba(139,0,0,0.1) 100%);
        border: 1px solid rgba(255, 0, 0, 0.3);
        padding: 10px 20px;
        border-radius: 12px;
        font-size: 0.8rem;
        color: var(--primary);
        font-weight: 700;
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }

    .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        border-color: rgba(255, 0, 0, 0.3);
        transform: translateY(-2px);
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: var(--gradient-red);
    }

    .stat-card h4 {
        color: var(--text-secondary);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    .stat-card .value {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--text-primary);
    }

    .admin-grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 24px;
        align-items: start;
        margin-bottom: 32px;
    }

    .form-card {
        position: sticky;
        top: 90px;
    }

    .form-card h3 {
        font-size: 1.1rem;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text-primary);
    }

    .requests-card {
        padding: 0;
        overflow: hidden;
    }

    .card-header {
        padding: 20px 24px;
        background: rgba(255, 0, 0, 0.05);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .card-header h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        color: var(--text-primary);
    }

    .action-btns {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .btn-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

    .btn-approve-icon {
        background: rgba(0, 208, 132, 0.15);
        color: var(--success);
        border: 1px solid rgba(0, 208, 132, 0.2);
    }

    .btn-approve-icon:hover {
        background: var(--success);
        color: #000;
        transform: scale(1.05);
    }

    .btn-reject-icon {
        background: rgba(255, 71, 87, 0.15);
        color: var(--danger);
        border: 1px solid rgba(255, 71, 87, 0.2);
    }

    .btn-reject-icon:hover {
        background: var(--danger);
        color: white;
        transform: scale(1.05);
    }

    .user-info-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--gradient-red);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: white;
        font-size: 1.1rem;
    }

    .user-details h5 {
        margin: 0;
        font-size: 0.95rem;
        color: var(--text-primary);
        font-weight: 600;
    }

    .user-details small {
        color: var(--text-secondary);
        font-size: 0.8rem;
    }

    .item-info strong {
        color: var(--text-primary);
        font-size: 0.95rem;
    }

    .item-info small {
        color: var(--text-secondary);
        font-size: 0.8rem;
        font-family: monospace;
    }

    /* Returns Section */
    .returns-section {
        margin-top: 40px;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .section-header h3 {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    /* Fine Form Styling */
    .fine-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .fine-form-row {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .fine-select {
        padding: 10px 14px;
        background: #0f0f0f;
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-primary);
        font-size: 0.85rem;
        cursor: pointer;
        min-width: 180px;
        transition: all 0.3s ease;
    }

    .fine-select:focus {
        outline: none;
        border-color: var(--primary);
    }

    .fine-input {
        padding: 10px 14px;
        background: #0f0f0f;
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-primary);
        font-size: 0.85rem;
        width: 140px;
        transition: all 0.3s ease;
    }

    .fine-input:focus {
        outline: none;
        border-color: var(--primary);
    }

    .fine-desc-input {
        padding: 10px 14px;
        background: #0f0f0f;
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text-primary);
        font-size: 0.85rem;
        flex: 1;
        min-width: 200px;
        transition: all 0.3s ease;
    }

    .fine-desc-input:focus {
        outline: none;
        border-color: var(--primary);
    }

    .btn-complete {
        padding: 10px 20px;
        background: var(--success);
        color: #000;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .btn-complete:hover {
        background: #00b370;
        transform: translateY(-2px);
    }

    .price-tag {
        font-weight: 700;
        color: var(--text-primary);
        font-size: 1rem;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 40px;
        color: var(--text-secondary);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .empty-state h4 {
        font-size: 1.2rem;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    /* Responsive */
    @media (max-width: 1200px) {
        .admin-grid {
            grid-template-columns: 1fr;
        }
        
        .form-card {
            position: static;
        }
        
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
        
        .fine-form-row {
            flex-direction: column;
            align-items: stretch;
        }
        
        .fine-select, .fine-input, .fine-desc-input {
            width: 100%;
        }
    }
</style>

<div class="dashboard-header animate-in">
    <div class="admin-badge">
        <span>🛡️</span> Admin Control Panel
    </div>
    <h1>Kelola Peminjaman</h1>
    <p>Verifikasi permintaan pengguna dan proses pengembalian barang</p>
</div>

<div class="stats-grid animate-in">
    <div class="stat-card">
        <h4>Permintaan Pending</h4>
        <div class="value"><%= pendingLoans.length %></div>
    </div>
    <div class="stat-card">
        <h4>Pengembalian Menunggu</h4>
        <div class="value"><%= returnRequests.length %></div>
    </div>
    <div class="stat-card">
        <h4>Total Diproses Hari Ini</h4>
        <div class="value">-</div>
    </div>
</div>

<div class="admin-grid animate-in">
    <!-- Add User Form -->
    <div class="card form-card">
        <h3><span>👤</span> Tambah Pengguna</h3>
        <form action="/admin/add-user" method="POST">
            <div class="form-group">
                <label>Nama Lengkap</label>
                <input type="text" name="name" class="form-control" placeholder="Contoh: John Doe" required>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-control" placeholder="email@domain.com" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" class="form-control" placeholder="Masukkan Password" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">
                <span>+</span> Daftarkan User
            </button>
        </form>
    </div>

    <!-- Pending Loans -->
    <div class="card requests-card">
        <div class="card-header">
            <h3>Persetujuan Peminjaman</h3>
            <span class="badge badge-warning"><%= pendingLoans.length %> Pending</span>
        </div>
        
        <% if(pendingLoans.length === 0) { %>
        <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h4>Tidak Ada Permintaan</h4>
            <p>Semua permintaan telah diproses</p>
        </div>
        <% } else { %>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Pengguna</th>
                    <th>Barang</th>
                    <th style="text-align: center; width: 100px;">Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% pendingLoans.forEach(loan => { %>
                <tr>
                    <td>
                        <div class="user-info-cell">
                            <div class="user-avatar"><%= (loan.User?.name || 'U').charAt(0).toUpperCase() %></div>
                            <div class="user-details">
                                <h5><%= loan.User?.name || 'Unknown' %></h5>
                                <small><%= loan.User?.email || '-' %></small>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="item-info">
                            <strong><%= loan.Item?.nama_barang || 'Unknown Item' %></strong>
                            <div><small><%= loan.Item?.kode_unit || '-' %></small></div>
                        </div>
                    </td>
                    <td>
                        <div class="action-btns">
                            <form action="/admin/approve/<%= loan.id %>" method="POST" style="display: inline;">
                                <button class="btn-icon btn-approve-icon" title="Terima">✓</button>
                            </form>
                            <form action="/admin/reject/<%= loan.id %>" method="POST" style="display: inline;">
                                <button class="btn-icon btn-reject-icon" title="Tolak">✕</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>

<!-- Returns Section -->
<div class="returns-section animate-in">
    <div class="section-header">
        <h3>Proses Pengembalian Barang</h3>
        <span class="badge badge-info"><%= returnRequests.length %> Menunggu</span>
    </div>
    
    <div class="card" style="padding: 0; overflow: hidden;">
        <% if(returnRequests.length === 0) { %>
        <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <h4>Tidak Ada Pengembalian</h4>
            <p>Tidak ada permintaan pengembalian yang menunggu</p>
        </div>
        <% } else { %>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Pengguna</th>
                    <th>Barang</th>
                    <th>Tagihan</th>
                    <th>Kondisi & Denda</th>
                    <th style="width: 120px;">Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% returnRequests.forEach(loan => { %>
                <tr>
                    <td>
                        <div class="user-info-cell">
                            <div class="user-avatar"><%= (loan.User?.name || 'U').charAt(0).toUpperCase() %></div>
                            <div class="user-details">
                                <h5><%= loan.User?.name || 'Unknown' %></h5>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="item-info">
                            <strong><%= loan.Item?.nama_barang || 'Unknown' %></strong>
                            <div><small><%= loan.Item?.kode_unit || '-' %></small></div>
                        </div>
                    </td>
                    <td>
                        <span class="price-tag">Rp <%= (loan.totalPrice || 0).toLocaleString('id-ID') %></span>
                    </td>
                    <td>
                        <form action="/admin/complete-return/<%= loan.id %>" method="POST" class="fine-form">
                            <div class="fine-form-row">
                                <select name="fineType" class="fine-select" onchange="updateFineInput(this, <%= loan.id %>)">
                                    <option value="none" data-fine="0">✓ Baik (Rp 0)</option>
                                    <option value="damaged" data-fine="100000">⚠ Rusak</option>
                                    <option value="lost" data-fine="500000">✕ Hilang</option>
                                </select>
                                
                                <input type="number" name="fineAmount" id="fine-<%= loan.id %>" 
                                    class="fine-input" placeholder="Nominal" 
                                    style="display: none;" min="0" step="1000">
                                
                                <input type="text" name="fineDescription" class="fine-desc-input" 
                                    placeholder="Keterangan (opsional)">
                            </div>
                        </form>
                    </td>
                    <td>
                        <button type="submit" form="fine-form-<%= loan.id %>" class="btn-complete">
                            Selesaikan
                        </button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>

<script>
function updateFineInput(select, loanId) {
    const input = document.getElementById('fine-' + loanId);
    const selected = select.options[select.selectedIndex];
    
    if (selected.value === 'damaged' || selected.value === 'lost') {
        input.style.display = 'block';
        input.value = '';
        input.placeholder = 'Nominal';
        input.required = true;
        input.focus();
    } else {
        input.style.display = 'none';
        input.value = selected.dataset.fine || 0;
        input.required = false;
    }
}

// Tambah ID ke form untuk button submit
document.querySelectorAll('.fine-form').forEach((form, index) => {
    form.id = 'fine-form-' + form.closest('tr').querySelector('input[name="fineAmount"]').id.replace('fine-', '');
});
</script>